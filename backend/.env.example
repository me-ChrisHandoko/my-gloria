# ═══════════════════════════════════════════════════════════
# My Gloria Backend - MVP Configuration
# ═══════════════════════════════════════════════════════════
# Minimum Viable Product setup for rapid development
# Uncomment advanced features as needed

# ───────────────────────────────────────────────────────────
# Application (REQUIRED)
# ───────────────────────────────────────────────────────────
APP_NAME=my-gloria-backend
APP_ENV=development
APP_PORT=8080
APP_HOST=0.0.0.0
APP_DEBUG=true

# ───────────────────────────────────────────────────────────
# Database (REQUIRED)
# ───────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3479
DB_USER=postgres
DB_PASSWORD=testing123
DB_NAME=gloria_v2
DB_SCHEMA=public
DB_SSLMODE=disable

# ───────────────────────────────────────────────────────────
# Authentication (REQUIRED)
# ───────────────────────────────────────────────────────────
JWT_SECRET=dev-secret-change-in-production-minimum-32-characters
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=168h

# ───────────────────────────────────────────────────────────
# Security Basics (REQUIRED)
# ───────────────────────────────────────────────────────────
# Argon2id password hashing parameters
ARGON2_MEMORY=65536
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=2
ARGON2_SALT_LENGTH=16
ARGON2_KEY_LENGTH=32

PASSWORD_MIN_LENGTH=8
MAX_LOGIN_ATTEMPTS=5

# ───────────────────────────────────────────────────────────
# CORS (REQUIRED)
# ───────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ───────────────────────────────────────────────────────────
# Optional Features (Disable for MVP)
# ───────────────────────────────────────────────────────────
# Uncomment and configure when needed

# Redis Caching (Optional - improve performance)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# Email Service (Optional - for notifications)
# EMAIL_ENABLED=false
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# Rate Limiting (Optional - API protection)
# RATE_LIMIT_ENABLED=false
# RATE_LIMIT_REQUESTS_PER_SECOND=10

# Monitoring (Optional - production observability)
# METRICS_ENABLED=false
# METRICS_PORT=9090

# Advanced Logging (Optional - file logging)
# LOG_FORMAT=json
# LOG_FILE_PATH=./logs/app.log

# Feature Flags (Optional - advanced features)
# FEATURE_EMAIL_VERIFICATION=false
# FEATURE_TWO_FACTOR_AUTH=false
# FEATURE_AUDIT_LOGGING=false

# Background Workers (Optional - async jobs)
# WORKER_ENABLED=false
# WORKER_CONCURRENCY=10

# ───────────────────────────────────────────────────────────
# Development Helpers
# ───────────────────────────────────────────────────────────
LOG_LEVEL=debug
TZ=Asia/Jakarta
