*.out
coverage/
*.coverprofile

# Dependency directories
vendor/

# Go workspace file
go.work
go.work.sum

# Environment files (NEVER commit these!)
.env
.env.local
.env.*.local
*.env
!.env.example

# IDE specific files
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Logs
logs/
*.log

# Temporary files
tmp/
temp/
*.tmp

