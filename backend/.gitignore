*.tar.gz
*.zip

# Database files
*.db
*.sqlite
*.sqlite3

# Storage files (uploaded files, etc.)
storage/
uploads/

# Docker volumes
docker-volumes/

# OS specific
Thumbs.db
.DS_Store

# Air live reload
tmp/

# Swagger generated files
docs/swagger/

# Migration temporary files
*.sql~

